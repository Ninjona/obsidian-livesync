COUCHDB_USER=obsidian
COUCHDB_PASSWORD=replace-with-a-long-random-secret
# Cookie auth signing secret — generate with: openssl rand -hex 32
ERLANG_COOKIE=replace-with-another-long-random-secret
COUCHDB_PORT=5984

# Needed only when enabling the optional caddy service in docker-compose.yml
DOMAIN=notes.example.com
ACME_EMAIL=admin@example.com

# Optional CouchDB JWT auth (applied by couchdb-init)
JWT_ENABLED=false
JWT_ALG=hmac
JWT_KID=_default
JWT_KEY=
JWT_USERNAME_CLAIM=
JWT_ROLES_CLAIM=
JWT_CLAIMS_REQUIRED=
JWT_AUDIENCE_CHECK=

# Setup URI generation (printed by couchdb-init container logs)
SETUP_URI_ENABLED=true
# Optional public URL your Obsidian clients should use.
# Leave empty to auto-derive http://localhost:${COUCHDB_PORT}
SETUP_URI_HOSTNAME=
SETUP_URI_DATABASE=obsidiannotes
# Optional overrides; leave empty to auto-generate secure values each run
SETUP_URI_LIVESYNC_PASSPHRASE=
SETUP_URI_URI_PASSPHRASE=
