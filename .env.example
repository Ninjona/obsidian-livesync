COUCHDB_USER=obsidian
COUCHDB_PASSWORD=replace-with-a-long-random-secret
# Cookie auth signing secret — generate with: openssl rand -hex 32
ERLANG_COOKIE=replace-with-another-long-random-secret
COUCHDB_PORT=5984

# Needed only when enabling the optional caddy service in docker-compose.yml
DOMAIN=notes.example.com
ACME_EMAIL=admin@example.com

# Optional CouchDB JWT auth (applied by couchdb-init)
JWT_ENABLED=false
JWT_ALG=hmac
JWT_KID=_default
JWT_KEY=
JWT_USERNAME_CLAIM=
JWT_ROLES_CLAIM=
JWT_CLAIMS_REQUIRED=
JWT_AUDIENCE_CHECK=

# Setup URI generation (printed by couchdb-init container logs)
SETUP_URI_ENABLED=true
# Optional public URL your Obsidian clients should use.
# Leave empty to auto-derive http://localhost:${COUCHDB_PORT}
SETUP_URI_HOSTNAME=
# Optional override for the passphrase that encrypts the setup URI.
# Leave empty to auto-generate a secure value each run.
SETUP_URI_PASSPHRASE=

# Users: each entry is user:password:database, separated by semicolons.
# Each user gets their own database (locked to them) and a setup URI.
# The admin user should be included here if they also sync a vault.
# Example: USERS=obsidian:adminpass:obsidiannotes;alice:secret123:vault-alice
USERS=

# Set to true to regenerate setup URIs for existing users on restart
FORCE_SETUP_URI=false
