COUCHDB_USER=obsidian
COUCHDB_PASSWORD=replace-with-a-long-random-secret
ERLANG_COOKIE=replace-with-another-long-random-secret
COUCHDB_PORT=5984

# Needed only for compose.caddy.yml
DOMAIN=notes.example.com
ACME_EMAIL=admin@example.com

# Optional CouchDB JWT auth (applied by couchdb-init)
JWT_ENABLED=false
JWT_ALG=hmac
JWT_KID=_default
JWT_KEY=
JWT_USERNAME_CLAIM=
JWT_ROLES_CLAIM=
JWT_CLAIMS_REQUIRED=
JWT_AUDIENCE_CHECK=
